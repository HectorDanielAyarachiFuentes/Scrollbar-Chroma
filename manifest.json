{
    "manifest_version": 3,
    "name": "Scrollbar Reimagined Premium",
    "version": "1.0",
    "description": "Transforma la barra de scroll convencional en una barra de diseño premium con gradientes y texto SVG.",
    "browser_specific_settings": {
        "gecko": {
            "strict_min_version": "142.0"
        }
    },
    "permissions": ["storage", "theme"],
    "background": {
        "scripts": ["background.js"]
    },
    "icons": {
        "16": "assets/icon.svg",
        "32": "assets/icon.svg",
        "48": "assets/icon.svg",
        "128": "assets/icon.svg"
    },
    "action": {
        "default_popup": "popup/popup.html",
        "default_title": "Scrollbar Reimagined Premium",
        "default_icon": "assets/icon.svg"
    },
    "options_ui": {
        "page": "popup/popup.html",
        "open_in_tab": false
    },
    "sidebar_action": {
        "default_title": "Scrollbar Premium",
        "default_panel": "popup/popup.html"
    },
    "content_scripts": [
        {
            "matches": ["<all_urls>"],
            "js": ["content/content.js"],
            "run_at": "document_start"
        }
    ]
}